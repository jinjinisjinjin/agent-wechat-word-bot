#!/bin/bash
# 腾讯云 SCF Web 函数启动脚本
# - Web Server 必须监听 9000 端口（平台转发）
# - 只有 /tmp 可写，用 DATA_DIR=/tmp 重定向持久化文件
# - 依赖已预装进 zip 内的 lib/ 目录，通过 PYTHONPATH 引入（不依赖云端 pip）
export PORT=9000
export DATA_DIR=/tmp

PY=/var/lang/python39/bin/python3.9
[ -x "$PY" ] || PY=/var/lang/python310/bin/python3.10
[ -x "$PY" ] || PY=/var/lang/python3/bin/python3

echo "[scf_bootstrap] 使用 Python: $PY"

# 依赖已预装进 lib/（打包时下载的 cp39-manylinux wheel），直接加入 PYTHONPATH
# 注意：SCF Web 函数代码根目录为 /var/user
export PYTHONPATH=/var/user/lib:$PYTHONPATH

echo "[scf_bootstrap] 依赖就绪，启动 main.py (监听 0.0.0.0:$PORT)"
exec "$PY" main.py
