# 端口配置（Flask 监听端口）
# 注意：macOS 系统会占用 5000 和 8080，建议使用 9090 或其他未被占用的端口
PORT=9090

# ===== 微信公众号接入（测试号 / 订阅号）=====
# 通道切换：official=微信公众号 / personal=cc-weixin 个人微信
WECHAT_CHANNEL=official
# 公众号后台「基本配置」填写的 Token（建议用 secrets.token_urlsafe(24) 生成）
MP_TOKEN=请填写你的Token
# 测试号 / 公众号的 appID 与 appsecret（在公众号后台或测试号页面获取）
MP_APPID=请填写你的AppID
MP_APPSECRET=请填写你的AppSecret
# 回调路径，需与公众号后台 URL 的路径部分一致
MP_CALLBACK_PATH=/wechat
